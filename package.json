{
    "name": "craft",
    "private": true,
    "workspaces": {
        "packages": [
            "apps/*",
            "packages/*"
        ],
        "catalog": {
            "dotenv": "^17.2.2",
            "zod": "^4.1.13",
            "lucide-react": "^0.546.0",
            "next": "^16.2.4",
            "next-themes": "^0.4.6",
            "react": "^19.2.5",
            "react-dom": "^19.2.5",
            "sonner": "^2.0.5",
            "@orpc/server": "^1.12.2",
            "@orpc/client": "^1.12.2",
            "@orpc/openapi": "^1.12.2",
            "@orpc/zod": "^1.12.2",
            "better-auth": "1.6.6",
            "@polar-sh/better-auth": "^1.8.3",
            "@types/react": "^19.2.14",
            "@types/react-dom": "^19.2.3",
            "tailwindcss": "^4.2.4"
        }
    },
    "type": "module",
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build",
        "check-types": "turbo check-types",
        "dev:web": "turbo -F web dev",
        "db:push": "turbo -F @craft/db db:push",
        "db:studio": "turbo -F @craft/db db:studio",
        "db:generate": "turbo -F @craft/db db:generate",
        "db:migrate": "turbo -F @craft/db db:migrate",
        "db:start": "turbo -F @craft/db db:start",
        "db:watch": "turbo -F @craft/db db:watch",
        "db:stop": "turbo -F @craft/db db:stop",
        "db:down": "turbo -F @craft/db db:down",
        "check": "ultracite check",
        "fix": "ultracite fix",
        "prepare": "husky"
    },
    "dependencies": {
        "@craft/env": "workspace:*",
        "dotenv": "catalog:",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.10",
        "@craft/config": "workspace:*",
        "@types/node": "^25.6.0",
        "husky": "latest",
        "lint-staged": "latest",
        "turbo": "^2.9.6",
        "typescript": "^6",
        "ultracite": "7.6.0"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
            "bun x ultracite fix"
        ]
    },
    "packageManager": "bun@1.3.10"
}
