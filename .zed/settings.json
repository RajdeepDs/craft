{
    "format_on_save": "on",
    "formatter": "language_server",
    "lsp": {
        "typescript-language-server": {
            "settings": {
                "typescript": {
                    "preferences": {
                        "includePackageJsonAutoImports": "on"
                    }
                }
            }
        },
        "tailwindcss-language-server": {
            "settings": {
                "experimental": {
                    "configFile": "packages/ui/src/styles/system.css"
                },
                "includeLanguages": {
                    "html": "html",
                    "javascript": "javascript",
                    "typescriptreact": "typescriptreact"
                }
            }
        }
    },
    "languages": {
        "JavaScript": {
            "code_actions_on_format": {
                "source.fixAll.biome": true,
                "source.organizeImports.biome": true
            },
            "formatter": {
                "language_server": {
                    "name": "biome"
                }
            }
        },
        "TSX": {
            "code_actions_on_format": {
                "source.fixAll.biome": true,
                "source.organizeImports.biome": true
            },
            "formatter": {
                "language_server": {
                    "name": "biome"
                }
            }
        },
        "TypeScript": {
            "code_actions_on_format": {
                "source.fixAll.biome": true,
                "source.organizeImports.biome": true
            },
            "formatter": {
                "language_server": {
                    "name": "biome"
                }
            }
        }
    }
}
